library(ggplot2)
library(VennDiagram)

path <- "C:\\Users\\bseun\\OneDrive - Nexus365\\Desktop\\PROTEOMICS TUM DOSYALAR\\astrocytes perseus\\"
pathResults_GFAP <- file.path(path, "results\\vsnNorm\\outlierRM2\\GFAP+ outlier removal after filter\\")
pathResults_ALDH1L1 <- file.path(path, "results\\vsnNorm\\outlierRM2\\ALDH1L1+ outlier removal after filter\\")
pathResults_comparison <- file.path(path, "results\\vsnNorm\\outlierRM2\\Outlier_detection_after_filter\\")
dir.create(pathResults_comparison, recursive = TRUE, showWarnings = FALSE)

# DEP sonuçlarını oku
GFAP_res <- read.csv(paste0(pathResults_GFAP, "sig_res_EBayes_adjusted_MS_vs_Ctrl_strict.csv"))
ALDH1L1_res <- read.csv(paste0(pathResults_ALDH1L1, "sig_res_EBayes_adjusted_MS_vs_Ctrl_strict.csv"))

# Protein listelerini al
GFAP_proteins <- unique(GFAP_res$Gene)
ALDH1L1_proteins <- unique(ALDH1L1_res$Gene)

# Ortak ve unique proteinleri bul
common_proteins <- intersect(GFAP_proteins, ALDH1L1_proteins)
unique_GFAP_proteins <- setdiff(GFAP_proteins, ALDH1L1_proteins)
unique_ALDH1L1_proteins <- setdiff(ALDH1L1_proteins, GFAP_proteins)

# Sayıları yazdır
cat("GFAP MS toplam DEP sayisi:", length(GFAP_proteins), "\n")
cat("ALDH1L1 MS toplam DEP sayisi:", length(ALDH1L1_proteins), "\n")
cat("Ortak protein sayisi:", length(common_proteins), "\n")
cat("Sadece GFAP MS'e unique protein sayisi:", length(unique_GFAP_proteins), "\n")
cat("Sadece ALDH1L1 MS'e unique protein sayisi:", length(unique_ALDH1L1_proteins), "\n")

# FIX 3: Dosya isimleri pairwise karşılaştırmayı yansıtacak şekilde güncellendi
write.csv(data.frame(Gene = common_proteins), paste0(pathResults_comparison, "common_GFAP_ALDH1L1_MS_proteins.csv"), row.names = FALSE)
write.csv(data.frame(Gene = unique_GFAP_proteins), paste0(pathResults_comparison, "unique_GFAP_vs_ALDH1L1_MS_proteins.csv"), row.names = FALSE)
write.csv(data.frame(Gene = unique_ALDH1L1_proteins), paste0(pathResults_comparison, "unique_ALDH1L1_vs_GFAP_MS_proteins.csv"), row.names = FALSE)

# Venn diagram
venn.plot <- draw.pairwise.venn(
  area1 = length(GFAP_proteins),
  area2 = length(ALDH1L1_proteins),
  cross.area = length(common_proteins),
  category = c("GFAP MS", "ALDH1L1 MS"),
  fill = c("#D22B2B", "#0096FF"),
  alpha = 0.5,
  cex = 2,
  cat.cex = 1.5,
  cat.pos = c(-20, 20)
)

png(paste0(pathResults_comparison, "Venn_GFAP_vs_ALDH1L1_MS_proteins.png"), width = 8, height = 6, units = "in", res = 300)
grid.draw(venn.plot)
dev.off()


